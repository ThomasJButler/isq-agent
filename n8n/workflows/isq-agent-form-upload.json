        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "file",
              "outputPropertyName": "xlsx"
            }
          }
        }
      },
      "id": "e5555555-5555-4555-8555-555555555555",
      "name": "Render XLSX",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [500, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://rag-service:8000/render",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            {
              "name": "format",
              "value": "json"
            },
            {
              "name": "envelope",
              "value": "={{ JSON.stringify($('POST /runs (answer)').item.json) }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "file",
              "outputPropertyName": "json"
            }
          }
        }
      },
      "id": "f6666666-6666-4666-8666-666666666666",
      "name": "Render JSON",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [740, 200]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Collect the three rendered files (each render node wrote its own binary property)\n// onto a single item so the next node can zip / return them together.\nreturn {\n  json: $('POST /runs (answer)').item.json.questionnaire_meta,\n  binary: {\n    docx: $('Render DOCX').item.binary.docx,\n    xlsx: $('Render XLSX').item.binary.xlsx,\n    json: $('Render JSON').item.binary.json\n  }\n};"
      },
      "id": "a7777777-7777-4777-8777-777777777777",
      "name": "Combine files",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [980, 200]
    },
    {
      "parameters": {
        "operation": "compress",
        "binaryPropertyName": "docx,xlsx,json",
        "outputFormat": "zip",
        "fileName": "isq-deliverables.zip",
        "binaryPropertyOutput": "data"
      },
      "id": "b8888888-8888-4888-8888-888888888888",
      "name": "Zip deliverables",
      "type": "n8n-nodes-base.compression",
      "typeVersion": 1.1,
      "position": [1220, 200]
    },
    {
      "parameters": {
        "operation": "completion",
        "respondWith": "returnBinary",
        "inputDataFieldName": "data",
        "completionTitle": "Your answered questionnaire is ready",
        "completionMessage": "Downloading the DOCX, XLSX and JSON as a zip. Low-confidence answers are flagged for review inside."
      },
      "id": "c9999999-9999-4999-8999-999999999999",
      "name": "Deliver download",
      "type": "n8n-nodes-base.form",
      "typeVersion": 1,
      "position": [1460, 200]
    }
  ],
