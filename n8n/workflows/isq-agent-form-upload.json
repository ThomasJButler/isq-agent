{
  "id": "isqAgentFormUpload01",
  "name": "ISQ Agent: form upload",
  "nodes": [
    {
      "parameters": {
        "formTitle": "ISQ Agent: upload a questionnaire",
        "formDescription": "Upload a blank ISQ (PDF, DOCX or XLSX). The agent answers each question from Northstar Labs' policies and returns the completed documents.",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Questionnaire",
              "fieldType": "file",
              "acceptFileTypes": ".pdf,.docx,.xlsx",
              "requiredField": true
            }
          ]
        },
        "options": {
          "path": "isq-upload"
        }
      },
      "id": "a1111111-1111-4111-8111-111111111111",
      "name": "Form Trigger",
      "type": "n8n-nodes-base.formTrigger",
      "typeVersion": 2.2,
      "position": [-220, 200],
      "webhookId": "b2222222-2222-4222-8222-222222222222"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://rag-service:8000/runs",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            {
              "parameterType": "formBinaryData",
              "name": "file",
              "inputDataFieldName": "Questionnaire"
            },
            {
              "name": "origin",
              "value": "n8n form upload"
            }
          ]
        },
        "options": {
          "timeout": 300000
        }
      },
      "id": "c3333333-3333-4333-8333-333333333333",
      "name": "POST /runs (answer)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [20, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://rag-service:8000/render",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            {
              "name": "format",
              "value": "docx"
            },
            {
              "name": "envelope",
              "value": "={{ JSON.stringify($('POST /runs (answer)').item.json) }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "file",
              "outputPropertyName": "docx"
            }
          }
        }
      },
      "id": "d4444444-4444-4444-8444-444444444444",
      "name": "Render DOCX",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [260, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://rag-service:8000/render",
        "sendBody": true,
