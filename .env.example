# ============================================================
# ISQ Agent — environment variables
# Copy to .env and fill in. NEVER commit .env.
# ============================================================

# ---------- Voyage AI (embeddings) ----------
# Get at: https://dash.voyageai.com → API Keys
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3-large

# ---------- Anthropic Claude (generation + extraction) ----------
# Get at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
# The service is model-agnostic: set ANTHROPIC_MODEL to any current Claude model and every
# call (generation, extraction, query rewriting) uses it. Confirm exact IDs in the console.
#   claude-sonnet-4-5  (default — fast, strong, cheap; good for a 20-question run)
#   claude-sonnet-4-6  (newer Sonnet)
#   claude-opus-4-7    (Opus — highest quality, slower + pricier per question)
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---------- Pinecone (vector store) ----------
# Get at: https://app.pinecone.io → API Keys
# Index must already exist (1024 dims, cosine, serverless)
PINECONE_API_KEY=pcsk-...
PINECONE_INDEX=isq-agent-knowledge

# ---------- Service config ----------
LOG_LEVEL=INFO
RAG_SERVICE_PORT=8000

# ---------- n8n (for the docker-compose stack) ----------
N8N_HOST=localhost
N8N_PORT=5678
